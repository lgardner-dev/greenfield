{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "toolchainFile": "${sourceDir}/cmake/vcpkg-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_ROOT": "${sourceDir}/.tools/vcpkg",
        "GREENFIELD_ALLOW_SYSTEM_DEPENDENCIES": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "toolchainFile": "${sourceDir}/cmake/vcpkg-toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "VCPKG_ROOT": "${sourceDir}/.tools/vcpkg",
        "GREENFIELD_ALLOW_SYSTEM_DEPENDENCIES": "OFF"
      }
    },
    {
      "name": "headless-fast2d",
      "displayName": "Headless Fast2D",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/headless-fast2d",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "GREENFIELD_BUILD_PROFILE": "headless-fast2d"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "headless-fast2d",
      "configurePreset": "headless-fast2d"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "headless-fast2d",
      "configurePreset": "headless-fast2d",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
